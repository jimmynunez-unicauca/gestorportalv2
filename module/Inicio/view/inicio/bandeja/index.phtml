    // Función para animar elementos al hacer scroll
    function animateOnScroll() {
        $('#mi-dashboard-container .info-card, #mi-dashboard-container .chart-card').each(function() {
            var elementTop = $(this).offset().top;
            var elementBottom = elementTop + $(this).outerHeight();
            var viewportTop = $(window).scrollTop();
            var viewportBottom = viewportTop + $(window).height();

            if (elementBottom > viewportTop && elementTop < viewportBottom) {
                $(this).addClass('animated fadeInUp');
            }
        });
    }

    function initDashboardTabs() {
        $('#mi-dashboard-container .tab-button').on('click', function() {
            var target = $(this).data('target');
            $('#mi-dashboard-container .tab-button').removeClass('active');
            $(this).addClass('active');
            $('#mi-dashboard-container .dashboard-pane').removeClass('active');
            $('#' + target).addClass('active');
        });
    }

    // Ejecutar animaciones al cargar y hacer scroll
    $(window).on('scroll', animateOnScroll);
    $(document).ready(function() {
        initDashboardTabs();
    });
    animateOnScroll();

    // Mejorar tooltips si el plugin está disponible
    if (typeof $.fn.tooltip === 'function') {
        $('#mi-dashboard-container [data-toggle="tooltip"]').tooltip({
            delay: {
                show: 300,
                hide: 100
            },
            html: true
        });
    }

    // Agregar efecto de carga a las gráficas
    $('#mi-dashboard-container .chart-card').each(function(index) {
        $(this).css('animation-delay', (index * 0.1) + 's');

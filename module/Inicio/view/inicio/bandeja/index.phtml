    // Función para inicializar el carrusel
    function initCarousel() {
        let currentSlide = 0;
        const track = $('#mi-dashboard-container .carousel-track');
        const slides = $('#mi-dashboard-container .carousel-slide');
        const dots = $('#mi-dashboard-container .carousel-dot');

        function getSlidesPerView() {
            if ($(window).width() <= 768) return 1;
            if ($(window).width() <= 1200) return 2;
            if ($(window).width() <= 1400) return 3;
            return 4;
        }

        function updateCarousel() {
            const slidesPerView = getSlidesPerView();
            const slideWidth = $('#mi-dashboard-container .carousel-slide').outerWidth(true);
            const maxSlide = Math.ceil(slides.length / slidesPerView) - 1;

            if (currentSlide < 0) currentSlide = maxSlide;
            if (currentSlide > maxSlide) currentSlide = 0;

            const offset = -currentSlide * slideWidth * slidesPerView;
            track.css('transform', `translateX(${offset}px)`);

            dots.removeClass('active');
            $(dots[currentSlide]).addClass('active');
        }

        $('#mi-dashboard-container .carousel-next').click(function() {
            currentSlide++;
            updateCarousel();
        });

        $('#mi-dashboard-container .carousel-prev').click(function() {
            currentSlide--;
            updateCarousel();
        });

        $('#mi-dashboard-container .carousel-dot').click(function() {
            currentSlide = $(this).data('slide');
            updateCarousel();
        });

        $(window).resize(function() {
            currentSlide = 0;
            updateCarousel();
        });

        updateCarousel();
    }


<?php
//--------- CARGAR MENSAJES DE ALERTA ------------------------------------------
$flash = $this->flashMessenger();
$notificaciones = [
    'success' => array_merge($flash->getSuccessMessages(), $flash->getCurrentSuccessMessages()),
    'error' => array_merge($flash->getErrorMessages(), $flash->getCurrentErrorMessages()),
    'alert' => array_merge($flash->getMessages(), $flash->getCurrentMessages()),
    'information' => array_merge($flash->getInfoMessages(), $flash->getCurrentInfoMessages()),
    'warning' => array_merge($flash->getWarningMessages(), $flash->getCurrentWarningMessages()),
];
$flash->clearCurrentMessages('default');
$flash->clearCurrentMessages('info');
$flash->clearCurrentMessages('success');
$flash->clearCurrentMessages('warning');
$flash->clearCurrentMessages('error');
$mostrarMensajes = '';
foreach (array_filter($notificaciones) as $tipo => $mensajes) {
    $tipoToastr = 'info';
    $titulo = 'GestorPortal';
    switch ($tipo) {
        case 'success':
            $titulo = '<b><i class="fas fa-check-circle"></i> GestorPortal</b>';
            $tipoToastr = 'success';
            break;
        case 'error':
            $titulo = '<b><i class="fas fa-exclamation-circle"></i> GestorPortal</b>';
            $tipoToastr = 'error';
            break;
        case 'alert':
        case 'warning':
            $titulo = '<b><i class="fas fa-exclamation-triangle"></i> GestorPortal</b>';
            $tipoToastr = 'warning';
            break;
        case 'information':
            $titulo = '<b><i class="fas fa-info-circle"></i> GestorPortal</b>';
            $tipoToastr = 'info';
            break;
    }
    foreach ($mensajes as $mensaje) {
        $mostrarMensajes .= "new PNotify({
            title: '$titulo',
            text: '$mensaje',
            type: '$tipoToastr',
            styling: 'bootstrap3',
            delay: 4000,
            animate: {
                animate: true,
                inClass: 'fadeInDown',
                outClass: 'fadeOutUp'
            }
        });";
    }
}
//------------------------------------------------------------------------------

$title = 'Inicio';
$this->headTitle($title);
$this->headScript()->prependScript(
    <<<JS
            $(document).ajaxStop($.unblockUI);
            $(document).ready(function() {
                $mostrarMensajes

                // Inicializar tooltips si el plugin está disponible (solo dentro del dashboard)
                if (typeof $.fn.tooltip === 'function') {
                    $('#mi-dashboard-container [data-toggle="tooltip"]').tooltip();
                }

                // Inicializar carrusel
                initCarousel();

                // Inicializar gráficas
                setTimeout(function() {
                    initCharts();
                }, 500);
            });
JS,
    'text/javascript',
    array('noescape' => true)
)
    ->prependFile($this->basePath('vendors/echarts/dist/echarts.min.js'))
    ->prependFile($this->basePath('js/sistema/evento.js'))
    ->prependFile($this->basePath('js/jquery.blockUI.js'));

$numeros = [
    'Académica' => $this->form_academica,
    'Agrarias' => $this->form_agraria,
    'Artes' => $this->form_artes,
    'CECAV' => $this->form_cecav,
    'C. Interés' => $this->form_conflicto_interes,
    'Contables' => $this->form_contables,
    'Posgrados' => $this->form_cp,
    'Cultura' => $this->form_cultura,
    'Emprendim' => $this->form_dae_empre,
    'Intelectu' => $this->form_dae_propiedad,
    'Egresados' => $this->form_egresados,
    'Emisora' => $this->form_emisora,
    'FCHS' => $this->form_fchs,
    'FIC' => $this->form_fic,
    'FIET' => $this->form_fiet,
    'OCDI' => $this->form_ocdi,
    'ORII' => $this->form_orii,
    'PQRSF' => $this->form_pqrsf,
    'Rectoría' => $this->form_rectoria,
    'R. Cuentas' => $this->form_rendicion_cuentas,
    'V. Admin' => $this->form_viceadmin,
    'V. Invest' => $this->form_viceinvest,
    'FACNED' => $this->form_facned,
    'F. Derecho' => $this->form_fderecho,
    'F. Salud' => $this->form_fsalud,
    'CoMarca' => $this->form_comarca,
    'Unisalud' => $this->form_unisalud,
    'Unisalud RC' => $this->form_unisalud_rendicion_cuentas,
];

// Sumar todos los valores
$total = array_sum($numeros);

// Calcular el porcentaje para cada valor
$porcentajes = [];
foreach ($numeros as $nombre => $numero) {
    if ($total > 0) {
        $porcentaje = ($numero / $total) * 100;
    } else {
        $porcentaje = 0;
    }
    $porcentajes[$nombre] = $porcentaje;
}

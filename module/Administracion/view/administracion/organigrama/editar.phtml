<script>
    $(document).ready(function() {
        // Inicializar Select2 con dropdownParent dentro del modal
        $('#padre_id').select2({
            allowClear: true,
            placeholder: "-- Ninguno (Raíz) --",
            width: '100%',
            dropdownParent: $('#modalFormulario')
        });

        $('#tipo').select2({
            width: '100%',
            dropdownParent: $('#modalFormulario')
        });

        $('#icono').select2({
            width: '100%',
            dropdownParent: $('#modalFormulario')
        });

        // Forzar foco en el input de búsqueda
        $('#padre_id').on('select2:open', function() {
            setTimeout(function() {
                var searchField = document.querySelector('.select2-search__field');
                if (searchField) {
                    searchField.focus();
                }
            }, 100);
        });

        var idNodo = $('#id').val();

        // Cargar ruta actual del nodo
        function cargarRutaActual() {
            if (idNodo) {
                $.ajax({
                    url: '<?= $this->url('administracion/organigrama', ['action' => 'apiRuta']) ?>',
                    type: 'GET',
                    data: {
                        id: idNodo
                    },
                    dataType: 'json',
                    success: function(data) {
                        if (data.ruta) {
                            $('#rutaActual').html('<strong>' + data.ruta + '</strong>');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.log('Error cargando ruta:', error);
                    }
                });
            }
        }

        // Cargar ruta del nuevo padre seleccionado
        function cargarRutaNueva(padreId) {
            if (padreId && padreId != '') {
                $.ajax({
                    url: '<?= $this->url('administracion/organigrama', ['action' => 'apiRuta']) ?>',
                    type: 'GET',
                    data: {
                        id: padreId
                    },
                    dataType: 'json',
                    success: function(data) {
                        if (data.ruta) {
                            $('#nuevaUbicacion').show();
                            $('#rutaNueva').html('<strong>' + data.ruta + '</strong> → <span class="text-primary">' + $('#nombre').val() + '</span>');
                        } else {
                            $('#nuevaUbicacion').hide();
                        }
                    },
                    error: function() {
                        $('#nuevaUbicacion').hide();
                    }
                });
            } else {
                $('#nuevaUbicacion').hide();
            }
        }

        $('#padre_id').on('change', function() {
            cargarRutaNueva($(this).val());
        });

        cargarRutaActual();

        if ($('#padre_id').val()) {
            cargarRutaNueva($('#padre_id').val());
        }
    });

    function validarGuardar(event, form, tipo) {
        event.preventDefault();

        if (CKEDITOR.instances['descripcion']) {
            CKEDITOR.instances['descripcion'].updateElement();
        }

        if ($('#nombre').val().trim() == '') {
            Swal.fire('Error', 'El nombre del nodo es requerido', 'error');
            return false;
        }

        Swal.fire({
            title: "¿DESEA " + tipo + " EL NODO?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Si",
            cancelButtonText: "No",
            allowOutsideClick: false
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
                bloqueoAjax();
            }
        });
        return false;
    }
</script>
<script>
    $(document).ready(function() {
        // Inicializar CKEditor en el campo descripcion
        if (CKEDITOR.instances['descripcion']) {
            CKEDITOR.instances['descripcion'].destroy();
        }
        CKEDITOR.replace('descripcion', {
            toolbar: [
                ['Bold', 'Italic', 'Underline', 'Strike'],
                ['NumberedList', 'BulletedList', '-', 'Outdent', 'Indent'],
                ['JustifyLeft', 'JustifyCenter', 'JustifyRight', 'JustifyBlock'],
                ['Link', 'Unlink'],
                ['FontSize', 'FontColor', 'TextColor'],
                ['Undo', 'Redo', 'Find', 'Replace'],
                ['RemoveFormat', 'Source']
            ],
            height: 250,
            language: 'es',
            enterMode: CKEDITOR.ENTER_BR,
            shiftEnterMode: CKEDITOR.ENTER_P,
            autoParagraph: false,
            fillEmptyBlocks: false,
            removePlugins: 'elementspath',
            removeButtons: 'Source'
        });
    });
</script>
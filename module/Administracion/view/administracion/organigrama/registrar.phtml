<script>
    $(document).ready(function() {
        // Destruir select2 previo si existe
        if ($('#padre_id').data('select2')) {
            $('#padre_id').select2('destroy');
        }
        if ($('#tipo').data('select2')) {
            $('#tipo').select2('destroy');
        }
        if ($('#icono').data('select2')) {
            $('#icono').select2('destroy');
        }

        // Inicializar Select2 correctamente dentro del modal
        $('#padre_id').select2({
            allowClear: true,
            placeholder: "-- Ninguno (Raíz) --",
            width: '100%',
            dropdownParent: $('#modalFormulario') // IMPORTANTE: para que funcione dentro del modal
        });

        $('#tipo').select2({
            width: '100%',
            dropdownParent: $('#modalFormulario')
        });

        $('#icono').select2({
            width: '100%',
            dropdownParent: $('#modalFormulario')
        });

        // Forzar que el input de búsqueda reciba foco al abrir
        $('#padre_id').on('select2:open', function() {
            setTimeout(function() {
                document.querySelector('.select2-search__field').focus();
            }, 100);
        });

        // Función para cargar la ruta del padre seleccionado
        function cargarRutaPadre(padreId) {
            if (padreId && padreId != '') {
                $.ajax({
                    url: '<?= $this->url('administracion/organigrama', ['action' => 'apiRuta']) ?>',
                    type: 'GET',
                    data: {
                        id: padreId
                    },
                    dataType: 'json',
                    success: function(data) {
                        if (data.ruta) {
                            $('#ubicacionActual').show();
                            $('#rutaPadre').html('<strong>' + data.ruta + '</strong> → <span class="text-primary">[NUEVO NODO]</span>');
                        } else {
                            $('#ubicacionActual').hide();
                        }
                    },
                    error: function() {
                        $('#ubicacionActual').hide();
                    }
                });
            } else {
                $('#ubicacionActual').hide();
            }
        }

        // Cargar ruta cuando cambie la selección del padre
        $('#padre_id').on('change', function() {
            cargarRutaPadre($(this).val());
        });

        // Cargar ruta inicial si hay un padre preseleccionado
        if ($('#padre_id').val()) {
            cargarRutaPadre($('#padre_id').val());
        }
    });

    function validarGuardar(event, form, tipo) {
        event.preventDefault();

        if (CKEDITOR.instances['descripcion']) {
            CKEDITOR.instances['descripcion'].updateElement();
        }

        if ($('#nombre').val().trim() == '') {
            Swal.fire('Error', 'El nombre del nodo es requerido', 'error');
            return false;
        }

        Swal.fire({
            title: "¿DESEA " + tipo + " EL NODO?",
            html: "<strong>" + $('#nombre').val() + "</strong><br>" + ($('#rutaPadre').html() ? 'Ubicación: ' + $('#rutaPadre').html() : 'Ubicación: Raíz'),
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Si",
            cancelButtonText: "No",
            allowOutsideClick: false
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
                bloqueoAjax();
            }
        });
        return false;
    }

    function bloqueoAjax() {
        $.blockUI({
            message: $('#msgBloqueo'),
            css: {
                border: 'none',
                padding: '15px',
                backgroundColor: '#000',
                '-webkit-border-radius': '10px',
                '-moz-border-radius': '10px',
                opacity: .85,
                color: '#fff',
                'z-index': 10000000
            }
        });
    }
</script>
<script>
    $(document).ready(function() {
        // Inicializar CKEditor en el campo descripcion
        CKEDITOR.replace('descripcion', {
            toolbar: [
                ['Bold', 'Italic', 'Underline'],
                ['NumberedList', 'BulletedList'],
                ['JustifyLeft', 'JustifyCenter', 'JustifyRight'],
                ['Link', 'Unlink'],
                ['FontSize', 'FontColor'],
                ['Undo', 'Redo']
            ],
            height: 200,
            removeButtons: 'Source',
            language: 'es'
        });
    });
</script>
                                    echo '<a href="javascript:verActivar(' . $qs['idNormatividad']  . ')" title="ACTIVAR" ' . $botonPlay . '><i class="fa fa-recycle" style="color:green;"></i></a>';
                                    echo '&nbsp;&nbsp;';

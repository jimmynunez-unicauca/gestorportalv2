                                foreach ($this->fetchAll as $qs) {
                                    $color = '';
                                    $botonPlay = '';
                                    $botonStop = '';
                                    $icono = '';
                                    $title = '';
                                    if ($qs['estado'] == 'Activo') {
                                        $color = 'green';
                                        $botonPlay = 'hidden';
                                        $botonStop = '';
                                    } else {
                                        $color = 'red';
                                        $botonPlay = '';
                                        $botonStop = 'hidden';
                                    }
                                    $ext = explode(".", strrev($qs['archivo']));
                                    if (strrev($ext[0]) == 'zip') {
                                        $icono = 'fa fa-file-archive-o';
                                        $title = 'DESCARGAR ZIP';
                                    } elseif (strrev($ext[0]) == 'pptx') {
                                        $icono = 'fa fa-file-powerpoint-o';
                                        $title = 'DESCARGAR POWERPOINT';
                                    } elseif (strrev($ext[0]) == 'xlsx') {
                                        $icono = 'fa fa-file-excel-o';
                                        $title = 'DESCARGAR EXCEL';
                                    } elseif (strrev($ext[0]) == 'docx') {
                                        $icono = 'fa fa-file-word-o';
                                        $title = 'DESCARGAR WORD';
                                    } else {
                                        $icono = 'fa fa-file-pdf-o';
                                        $title = 'DESCARGAR PDF';
                                    }
                                    echo '<tr>';
                                    echo '<td>' . $qs['idNormatividad']  . '</td>';
                                    echo '<td>';

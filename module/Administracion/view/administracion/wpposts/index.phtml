<script>
    $('#btnFiltrar').click(function() {
        // Obtener valores de los filtros
        const fechaInicio = $('#fechaInicio').val();
        const fechaFin = $('#fechaFin').val();
        const usuarioId = $('#usuario').val();
        // Validación básica de fechas
        if (fechaInicio && fechaFin && new Date(fechaInicio) > new Date(fechaFin)) {
            new PNotify({
                title: 'Error',
                text: 'La fecha de inicio no puede ser mayor a la fecha fin',
                type: 'error',
                styling: 'bootstrap3'
            });
            return;
        }
        // Redirección directa (igual que la URL manual)
        const url = `<?= $this->url('administracion/wpposts', ['action' => 'index']) ?>?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}&usuarioId=${usuarioId}`;
        window.location.href = url;
    });

    $('#btnLimpiar').click(function() {
        $('#fechaInicio, #fechaFin, #usuario').val('');
    });

    $(document).ready(function() {
        // Función para obtener parámetros de la URL
        function getQueryParam(param) {
            const urlParams = new URLSearchParams(window.location.search);
            return urlParams.get(param) || '';
        }
        // Obtener valores de los parámetros
        const fechaInicio = getQueryParam('fechaInicio');
        const fechaFin = getQueryParam('fechaFin');
        const usuarioId = getQueryParam('usuarioId');
        // Establecer valores en los campos de filtro
        if (fechaInicio) $('#fechaInicio').val(fechaInicio);
        if (fechaFin) $('#fechaFin').val(fechaFin);
        if (usuarioId) $('#usuario').val(usuarioId);
    });

    /* --------------------------------------------------------------------- */
    // Función para construir URL de exportación
    function getExportUrl(format) {
        const fechaInicio = $('#fechaInicio').val();
        const fechaFin = $('#fechaFin').val();
        const usuarioId = $('#usuario').val();

        const params = new URLSearchParams();
        if (fechaInicio) params.append('fechaInicio', fechaInicio);
        if (fechaFin) params.append('fechaFin', fechaFin);
        if (usuarioId) params.append('usuarioId', usuarioId);

        return `<?= $this->url('administracion/wpposts', ['action' => 'export']) ?>?${params.toString()}&format=${format}`;
    }

    // Eventos para los botones de exportación
    $('#btnExportExcel').click(function(e) {
        e.preventDefault();
        window.location.href = getExportUrl('excel');
    });

    $('#btnExportPDF').click(function(e) {
        e.preventDefault();
        window.location.href = getExportUrl('pdf');
    });
</script>
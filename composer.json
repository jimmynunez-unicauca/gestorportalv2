{
    "name": "laminas/laminas-mvc-skeleton",
    "description": "Laminas MVC Skeleton Application",
    "type": "project",
    "license": "BSD-3-Clause",
    "keywords": [
        "laminas",
        "mvc",
        "skeleton",
        "framework"
    ],
    "require": {
        "php": "^7.4 || ^8.0 || ^8.1 || ^8.2",
        "laminas/laminas-component-installer": "^2.8",
        "laminas/laminas-crypt": "^3.12",
        "laminas/laminas-db": "^2.19",
        "laminas/laminas-development-mode": "^3.8",
        "laminas/laminas-file": "^2.13",
        "laminas/laminas-http": "^2.19",
        "laminas/laminas-i18n": "^2.33",
        "laminas/laminas-json": "^3.5",
        "laminas/laminas-mvc": "^3.4",
        "laminas/laminas-mvc-middleware": "^2.5",
        "laminas/laminas-mvc-plugin-fileprg": "^1.7",
        "laminas/laminas-mvc-plugins": "^1.2",
        "laminas/laminas-navigation": "^2.16",
        "laminas/laminas-permissions-rbac": "^3.3",
        "laminas/laminas-session": "^2.16",
        "laminas/laminas-validator": "^2.45",
        "laminas/laminas-zendframework-bridge": "^1.8",
        "phpoffice/phpspreadsheet": "^5.8",
        "tecnickcom/tcpdf": "^6.7"
    },
    "autoload": {
        "psr-4": {
            "Layout\\": "module/Layout/src/",
            "Administracion\\": "module/Administracion/src/",
            "Formularios\\": "module/Formularios/src/",
            "Documentos\\": "module/Documentos/src/",
            "Inicio\\": "module/Inicio/src/",
            "Usermanager\\": "module/Usermanager/src/",
            "Usuarios\\": "module/Usuarios/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LayoutTest\\": "module/Layout/test/"
        }
    },
    "scripts": {
        "cs-check": "vendor/bin/phpcs",
        "cs-fix": "vendor/bin/phpcbf",
        "development-disable": "laminas-development-mode disable",
        "development-enable": "laminas-development-mode enable",
        "development-status": "laminas-development-mode status",
        "serve": "php -S 0.0.0.0:8080 -t public",
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "allow-plugins": {
            "laminas/laminas-component-installer": true
        },
        "sort-packages": true
    }
}
